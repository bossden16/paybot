### Copy this to .env.production and fill values. Do NOT commit secrets.

# App
BACKEND_URL=https://your-production-domain.com
DATABASE_URL=postgresql://user:pass@host:5432/dbname
JWT_SECRET_KEY=replace_with_secure_random_value

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=

# Maya Manager Checkout (Maya Manager v1)
MAYA_SECRET_KEY=
MAYA_MODE=live
MAYA_BASE_URL=https://pg.paymaya.com/p3/pay
MAYA_WEBHOOK_SECRET=

# Maya Business API (card payments / Business API)
MAYA_BUSINESS_API_KEY=
MAYA_BUSINESS_SECRET_KEY=
MAYA_BUSINESS_MODE=live
MAYA_BUSINESS_BASE_URL=https://api.paymaya.com

# Other production secrets
# DO NOT COMMIT
